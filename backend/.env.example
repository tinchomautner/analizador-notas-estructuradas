# Copiá este archivo como .env y completá las claves del backend.
# El proveedor de LLM se configura ACÁ, a nivel backend (no por usuario).

# Proveedor activo para parseo + narrativa: openai | anthropic
LLM_PROVIDER=openai

# --- OpenAI (proveedor actual) ---
OPENAI_API_KEY=sk-...
# Modelo: gpt-4o recomendado (transcribe los números y no inventa). gpt-4o-mini es
# más barato pero mete placeholders/errores en el informe narrativo.
OPENAI_MODEL=gpt-4o

# --- Anthropic (para volver a cambiar más adelante) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Cantidad de trayectorias Monte Carlo (default 10000).
MC_PATHS=10000

# Semilla para reproducibilidad.
MC_SEED=42
